<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>TAOT Admin</title>
</head>
<body>
<script src="https://unpkg.com/decap-cms@3.0.0/dist/decap-cms.js"></script>
</body>
</html>
backend:
  name: github
  repo: ahmedaharoon-byte/taot-site
  branch: main

media_folder: "images"
public_folder: "/images"

collections:
  - name: "products"
    label: "Products"
    folder: "products"
    create: true
    slug: "{{slug}}"
    fields:
      - {label: "Product Name", name: "title", widget: "string"}
      - {label: "Price", name: "price", widget: "string"}
      - {label: "Image", name: "image", widget: "image"}
      - {label: "Description", name: "body", widget: "text"}
